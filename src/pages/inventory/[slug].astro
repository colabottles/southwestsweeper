---
import { contentfulClient } from "../../lib/contentful";
import type { InventoryItem } from "../../types/contentful";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const entries = await contentfulClient.getEntries<InventoryItem>({
    content_type: "inventoryItem",
  });

  return entries.items.map((item) => ({
    params: { slug: item.fields.slug },
    props: { item: item.fields, id: item.sys.id },
  }));
}

const { item, id } = Astro.props;

const imageUrl =
  item.image && "fields" in item.image && item.image.fields?.file?.url
    ? `https:${item.image.fields.file.url}`
    : null;
---

<Layout title={item.name}>
  <main class="site-main">
    <div class="inv-detail-page">
      <div class="container container--medium">
        <a href="/inventory" class="inv-detail-back">← Back to Inventory</a>

        <div class="inv-detail-grid">
          <div class="inv-detail-image-col">
            {
              imageUrl ? (
                <img
                  src={imageUrl}
                  alt={item.name}
                  width="600"
                  height="450"
                  class="inv-detail-img"
                />
              ) : (
                <div class="inv-detail-img-placeholder">No image available</div>
              )
            }
          </div>

          <div class="inv-detail-content">
            <span class="inv-card-category">{item.category}</span>
            <h1 class="inv-detail-name">{item.name}</h1>

            <span
              class={`inv-detail-status ${item.inStock ? "inv-card-status--in" : "inv-card-status--out"}`}
            >
              {item.inStock ? "In Stock" : "Out of Stock"}
            </span>

            <p class="inv-detail-desc">{item.description}</p>

            <dl class="inv-detail-pricing">
              <div class="inv-detail-price-row">
                <dt>Per Day</dt>
                <dd>${item.pricePerDay ?? "—"}</dd>
              </div>
              <div class="inv-detail-price-row">
                <dt>Per Week</dt>
                <dd>${item.pricePerWeek ?? "—"}</dd>
              </div>
              <div class="inv-detail-price-row">
                <dt>Per Month</dt>
                <dd>${item.pricePerMonth ?? "—"}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .inv-detail-page {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .inv-detail-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--color-primary-700);
    margin-bottom: 2rem;
    transition: color 200ms linear;
  }

  .inv-detail-back:hover {
    color: var(--color-primary-500);
  }

  :global(.dark) .inv-detail-back {
    color: var(--color-primary-300);
  }

  .inv-detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .inv-detail-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .inv-detail-img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    object-fit: cover;
    box-shadow: var(--shadow-lg);
  }

  .inv-detail-img-placeholder {
    width: 100%;
    height: 300px;
    border-radius: 1rem;
    background-color: var(--color-base-200);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-base-600);
  }

  :global(.dark) .inv-detail-img-placeholder {
    background-color: var(--color-base-dark-700);
  }

  .inv-detail-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .inv-detail-name {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .inv-detail-status {
    display: inline-flex;
    width: fit-content;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.025em;
  }

  .inv-detail-desc {
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.8;
  }

  .inv-detail-pricing {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
    padding: 1.5rem;
    border-radius: 0.75rem;
    background-color: var(--bg-card);
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .inv-detail-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-base-200);
  }

  :global(.dark) .inv-detail-price-row {
    border-bottom-color: var(--color-base-dark-700);
  }

  .inv-detail-price-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .inv-detail-price-row dt {
    font-weight: 500;
    opacity: 0.7;
  }

  .inv-detail-price-row dd {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-primary-800);
  }

  :global(.dark) .inv-detail-price-row dd {
    color: var(--color-primary-300);
  }
</style>
