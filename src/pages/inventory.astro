---
import { contentfulClient } from "../lib/contentful";
import type { InventoryItem } from "../types/contentful";
import Layout from "../layouts/Layout.astro";

const entries = await contentfulClient.getEntries<InventoryItem>({
  content_type: "inventoryItem",
  order: ["fields.category", "fields.name"] as any,
});

const items = entries.items.map((item) => ({
  ...item.fields,
  slug: item.fields.slug,
  id: item.sys.id,
  imageUrl:
    item.fields.image &&
    "fields" in item.fields.image &&
    item.fields.image.fields?.file?.url
      ? `https:${item.fields.image.fields.file.url}`
      : null,
}));

const categories = [...new Set(items.map((i) => i.category))].sort();
---

<Layout title="Inventory">
  <main class="site-main">
    <div class="inventory-page">
      <div class="container container--wide">
        <div class="section-header">
          <div class="title2"><h2>Available Equipment</h2></div>
          <h1 class="title">Current Inventory</h1>
          <p class="subtitle">
            Browse our available equipment. Filter by category or sort to find
            what you need.
          </p>
        </div>

        <div class="inventory-controls">
          <nav class="inventory-filter-nav" aria-label="Filter by category">
            <ul role="list" class="inventory-filter-list">
              <li>
                <button
                  class="inventory-filter-btn"
                  data-filter="all"
                  aria-pressed="true">All</button
                >
              </li>
              {
                categories.map((cat) => (
                  <li>
                    <button
                      class="inventory-filter-btn"
                      data-filter={cat}
                      aria-pressed="false"
                    >
                      {cat}
                    </button>
                  </li>
                ))
              }
            </ul>
          </nav>

          <div class="inventory-sort">
            <label for="sort-select">Sort by:</label>
            <select id="sort-select" class="inventory-sort-select">
              <option value="name-asc">Name (A–Z)</option>
              <option value="name-desc">Name (Z–A)</option>
              <option value="price-asc">Price (Low–High)</option>
              <option value="price-desc">Price (High–Low)</option>
              <option value="status">In Stock First</option>
            </select>
          </div>
        </div>

        <div class="inventory-results">
          <p class="inventory-count" id="inventory-count" aria-live="polite">
          </p>
        </div>

        <ul role="list" id="inventory-list" class="inventory-list">
          {
            items.map((item) => (
              <li
                class="inv-list-item"
                data-category={item.category}
                data-name={item.name.toLowerCase()}
                data-price={item.pricePerDay ?? 0}
                data-instock={item.inStock ? "true" : "false"}
              >
                <div class="inv-list-link">
                  <div class="inv-list-image-wrap">
                    {item.imageUrl ? (
                      <img
                        src={item.imageUrl}
                        alt={item.name}
                        width="120"
                        height="90"
                        class="inv-list-img"
                      />
                    ) : (
                      <div class="inv-list-img-placeholder" aria-hidden="true">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="32"
                          height="32"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                          aria-hidden="true"
                        >
                          <rect x="3" y="3" width="18" height="18" rx="2" />
                          <circle cx="8.5" cy="8.5" r="1.5" />
                          <path d="m21 15-5-5L5 21" />
                        </svg>
                      </div>
                    )}
                  </div>

                  <div class="inv-list-body">
                    <div class="inv-list-meta">
                      <span class="inv-list-category">{item.category}</span>
                      <span
                        class={`inv-list-status ${item.inStock ? "inv-list-status--in" : "inv-list-status--out"}`}
                      >
                        {item.inStock ? "In Stock" : "Out of Stock"}
                      </span>
                    </div>
                    <h2 class="inv-list-name">{item.name}</h2>
                    <p class="inv-list-desc">{item.description}</p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>

        {
          items.length === 0 && (
            <div class="inventory-empty">
              <p>
                No inventory items available at this time. Please check back
                soon.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>("[data-filter]");
  const sortSelect = document.getElementById(
    "sort-select",
  ) as HTMLSelectElement;
  const list = document.getElementById("inventory-list") as HTMLUListElement;
  const countEl = document.getElementById(
    "inventory-count",
  ) as HTMLParagraphElement;

  let currentFilter = "all";

  function getItems() {
    return Array.from(list.querySelectorAll<HTMLLIElement>(".inv-list-item"));
  }

  function updateCount() {
    const visible = getItems().filter((i) => !i.hidden).length;
    countEl.textContent = `Showing ${visible} item${visible !== 1 ? "s" : ""}`;
  }

  function applyFilter() {
    getItems().forEach((item) => {
      item.hidden =
        currentFilter !== "all" && item.dataset.category !== currentFilter;
    });
    updateCount();
  }

  function applySort() {
    const val = sortSelect.value;
    const items = getItems();

    items.sort((a, b) => {
      if (val === "name-asc")
        return (a.dataset.name ?? "").localeCompare(b.dataset.name ?? "");
      if (val === "name-desc")
        return (b.dataset.name ?? "").localeCompare(a.dataset.name ?? "");
      if (val === "price-asc")
        return Number(a.dataset.price) - Number(b.dataset.price);
      if (val === "price-desc")
        return Number(b.dataset.price) - Number(a.dataset.price);
      if (val === "status") return a.dataset.instock === "true" ? -1 : 1;
      return 0;
    });

    items.forEach((item) => list.appendChild(item));
    applyFilter();
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      currentFilter = btn.dataset.filter ?? "all";
      filterBtns.forEach((b) => b.setAttribute("aria-pressed", "false"));
      btn.setAttribute("aria-pressed", "true");
      applyFilter();
    });
  });

  sortSelect.addEventListener("change", applySort);

  updateCount();
</script>

<style>
  .inventory-page {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  /* Controls row */
  .inventory-controls {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .inventory-controls {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  /* Filter nav */
  .inventory-filter-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .inventory-filter-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    border: 1px solid var(--color-primary-700);
    background-color: transparent;
    color: var(--color-primary-800);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      background-color 200ms linear,
      color 200ms linear;
  }

  :global(.dark) .inventory-filter-btn {
    color: var(--color-primary-200);
    border-color: var(--color-primary-600);
  }

  .inventory-filter-btn:hover,
  .inventory-filter-btn[aria-pressed="true"] {
    background-color: var(--color-primary-900);
    color: var(--color-accent-light);
    border-color: var(--color-primary-900);
  }

  :global(.dark) .inventory-filter-btn:hover,
  :global(.dark) .inventory-filter-btn[aria-pressed="true"] {
    background-color: var(--color-primary-700);
    border-color: var(--color-primary-700);
    color: var(--color-accent-light);
  }

  /* Sort */
  .inventory-sort {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .inventory-sort-select {
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-primary-700);
    background-color: var(--bg-card);
    color: var(--text-body);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    cursor: pointer;
  }

  :global(.dark) .inventory-sort-select {
    border-color: var(--color-primary-600);
  }

  /* Count */
  .inventory-count {
    font-size: 0.9rem;
    opacity: 0.6;
    margin-bottom: 1rem;
  }

  /* List */
  .inventory-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* List item */
  .inv-list-item {
    border-radius: 0.75rem;
    background-color: var(--bg-card);
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .inv-list-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
  }

  /* Image */
  .inv-list-image-wrap {
    flex-shrink: 0;
    width: 120px;
    height: 90px;
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: var(--color-base-200);
  }

  :global(.dark) .inv-list-image-wrap {
    background-color: var(--color-base-dark-700);
  }

  .inv-list-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .inv-list-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-base-500);
  }

  /* Body */
  .inv-list-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .inv-list-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .inv-list-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-700);
  }

  :global(.dark) .inv-list-category {
    color: var(--color-primary-300);
  }

  .inv-list-status {
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.025em;
  }

  .inv-list-status--in {
    background-color: var(--color-primary-900);
    color: var(--color-accent-light);
  }

  .inv-list-status--out {
    background-color: var(--color-base-dark-500);
    color: var(--color-accent-light);
  }

  .inv-list-name {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .inv-list-desc {
    font-size: 0.875rem;
    line-height: 1.5;
    opacity: 0.65;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Arrow */
  .inv-list-arrow {
    flex-shrink: 0;
    font-size: 1.5rem;
    opacity: 0.4;
    padding-left: 0.5rem;
  }

  /* Empty state */
  .inventory-empty {
    text-align: center;
    padding: 4rem 0;
    opacity: 0.6;
    font-size: 1.125rem;
  }
</style>
