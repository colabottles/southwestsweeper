---
import { contentfulClient } from "../lib/contentful";
import type { InventoryItem } from "../types/contentful";
import Layout from "../layouts/Layout.astro";

const entries = await contentfulClient.getEntries<InventoryItem>({
  content_type: "inventoryItem",
  order: ["fields.category", "fields.name"] as any,
});

const items = entries.items.map((item) => ({
  ...item.fields,
  id: item.sys.id,
  imageUrl:
    item.fields.image &&
    "fields" in item.fields.image &&
    item.fields.image.fields?.file?.url
      ? `https:${item.fields.image.fields.file.url}`
      : null,
}));

// Get unique categories for filtering
const categories = [...new Set(items.map((i) => i.category))].sort();
---

<Layout title="Inventory">
  <main>
    <h1>Inventory</h1>

    <nav aria-label="Filter by category">
      <ul role="list">
        <li><button data-filter="all">All</button></li>
        {
          categories.map((cat) => (
            <li>
              <button data-filter={cat}>{cat}</button>
            </li>
          ))
        }
      </ul>
    </nav>

    <ul role="list" id="inventory-list">
      {
        items.map((item) => (
          <li data-category={item.category}>
            {item.imageUrl && (
              <img
                src={item.imageUrl}
                alt={item.name}
                width="400"
                height="300"
              />
            )}
            <h2>{item.name}</h2>
            <p>{item.description}</p>
            <p>
              <span class={item.inStock ? "in-stock" : "out-of-stock"}>
                {item.inStock ? "In Stock" : "Out of Stock"}
              </span>
            </p>
            <dl>
              <>
                <dt>Per Day</dt>
                <dd>${item.pricePerDay}</dd>
              </>
              <>
                <dt>Per Week</dt>
                <dd>${item.pricePerWeek}</dd>
              </>
              <>
                <dt>Per Month</dt>
                <dd>${item.pricePerMonth}</dd>
              </>
            </dl>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
  const items = document.querySelectorAll<HTMLLIElement>("[data-category]");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      items.forEach((item) => {
        item.hidden = filter !== "all" && item.dataset.category !== filter;
      });
      buttons.forEach((b) => b.removeAttribute("aria-pressed"));
      btn.setAttribute("aria-pressed", "true");
    });
  });
</script>
