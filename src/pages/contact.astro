---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Us">
  <main class="site-main">
    <div class="contact-page">
      <div class="container container--wide">
        <div class="section-header">
          <div class="title2"><h2>Get In Touch</h2></div>
          <h1 class="title">Contact Us</h1>
          <p class="subtitle">
            Have a question or ready to get started? We'd love to hear from you.
          </p>
        </div>

        <div class="contact-layout">
          <div class="contact-info">
            <h2 class="contact-info-heading">Southwest Sweeper Sales</h2>
            <ul class="contact-details" role="list">
              <li>
                <span class="contact-label">Phone</span>
                <a href="tel:+16025551234" class="contact-value"
                  >(602) 555-1234</a
                >
              </li>
              <li>
                <span class="contact-label">Email</span>
                <a
                  href="mailto:info@southwestsweepersales.com"
                  class="contact-value">info@southwestsweepersales.com</a
                >
              </li>
              <li>
                <span class="contact-label">Hours</span>
                <span class="contact-value">Mon–Fri, 8am–5pm MST</span>
              </li>
            </ul>
          </div>

          <div class="contact-form-wrap">
            <form
              id="contact-form"
              class="contact-form"
              novalidate
              aria-label="Contact form"
            >
              <div class="form-row">
                <div class="form-group">
                  <label for="first-name"
                    >First Name <span aria-hidden="true">*</span></label
                  >
                  <input
                    type="text"
                    id="first-name"
                    name="firstName"
                    autocomplete="given-name"
                    required
                    aria-required="true"
                    aria-describedby="first-name-error"
                  />
                  <span
                    class="field-error"
                    id="first-name-error"
                    role="alert"
                    aria-live="polite"></span>
                </div>
                <div class="form-group">
                  <label for="last-name"
                    >Last Name <span aria-hidden="true">*</span></label
                  >
                  <input
                    type="text"
                    id="last-name"
                    name="lastName"
                    autocomplete="family-name"
                    required
                    aria-required="true"
                    aria-describedby="last-name-error"
                  />
                  <span
                    class="field-error"
                    id="last-name-error"
                    role="alert"
                    aria-live="polite"></span>
                </div>
              </div>

              <div class="form-group">
                <label for="email"
                  >Email Address <span aria-hidden="true">*</span></label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  aria-required="true"
                  aria-describedby="email-error"
                />
                <span
                  class="field-error"
                  id="email-error"
                  role="alert"
                  aria-live="polite"></span>
              </div>

              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  aria-describedby="phone-hint"
                />
                <span class="field-hint" id="phone-hint"
                  >Optional. Format: (555) 555-5555</span
                >
              </div>

              <div class="form-group">
                <label for="subject"
                  >Subject <span aria-hidden="true">*</span></label
                >
                <select
                  id="subject"
                  name="subject"
                  required
                  aria-required="true"
                  aria-describedby="subject-error"
                >
                  <option value="">Select a subject…</option>
                  <option value="sales">Equipment Sales</option>
                  <option value="rentals">Rentals</option>
                  <option value="parts">Parts & Service</option>
                  <option value="facility">Facility Services</option>
                  <option value="other">Other</option>
                </select>
                <span
                  class="field-error"
                  id="subject-error"
                  role="alert"
                  aria-live="polite"></span>
              </div>

              <div class="form-group">
                <label for="message"
                  >Message <span aria-hidden="true">*</span></label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  required
                  aria-required="true"
                  aria-describedby="message-error message-hint"></textarea>
                <span class="field-hint" id="message-hint"
                  >Minimum 10 characters.</span
                >
                <span
                  class="field-error"
                  id="message-error"
                  role="alert"
                  aria-live="polite"></span>
              </div>

              <p class="required-note">
                Fields marked with <span aria-hidden="true">*</span><span
                  class="sr-only">an asterisk</span
                > are required.
              </p>

              <div class="form-actions">
                <button type="submit" class="btn-submit" id="submit-btn">
                  Send Message
                </button>
              </div>

              <div
                id="form-success"
                class="form-success"
                role="status"
                aria-live="polite"
                aria-atomic="true"
                hidden
              >
                <p>
                  Thank you! Your message has been sent. We'll be in touch
                  shortly.
                </p>
              </div>

              <div
                id="form-error"
                class="form-error-banner"
                role="alert"
                aria-live="assertive"
                aria-atomic="true"
                hidden
              >
                <p>
                  Something went wrong. Please try again or call us directly.
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const successMsg = document.getElementById("form-success") as HTMLElement;
  const errorBanner = document.getElementById("form-error") as HTMLElement;

  const validators: Record<string, (val: string) => string> = {
    firstName: (v) => (v.trim() === "" ? "First name is required." : ""),
    lastName: (v) => (v.trim() === "" ? "Last name is required." : ""),
    email: (v) =>
      !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)
        ? "A valid email address is required."
        : "",
    subject: (v) => (v === "" ? "Please select a subject." : ""),
    message: (v) =>
      v.trim().length < 10 ? "Message must be at least 10 characters." : "",
  };

  function getError(name: string): HTMLElement | null {
    return document.getElementById(
      `${name.replace(/([A-Z])/g, "-$1").toLowerCase()}-error`,
    );
  }

  function validateField(
    input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement,
  ): boolean {
    const validator = validators[input.name];
    if (!validator) return true;
    const msg = validator(input.value);
    const errorEl = getError(input.name);
    if (errorEl) errorEl.textContent = msg;
    input.setAttribute("aria-invalid", msg ? "true" : "false");
    return msg === "";
  }

  // Validate on blur
  form.querySelectorAll("input, select, textarea").forEach((el) => {
    el.addEventListener("blur", () => {
      validateField(el as HTMLInputElement);
    });
    // Clear error on input
    el.addEventListener("input", () => {
      const errorEl = getError((el as HTMLInputElement).name);
      if (errorEl && errorEl.textContent !== "") {
        validateField(el as HTMLInputElement);
      }
    });
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Validate all fields
    const fields = Array.from(
      form.querySelectorAll("input, select, textarea"),
    ) as (HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)[];
    const valid = fields.map(validateField).every(Boolean);

    if (!valid) {
      // Move focus to first invalid field
      const firstInvalid = fields.find(
        (f) => f.getAttribute("aria-invalid") === "true",
      );
      firstInvalid?.focus();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";
    successMsg.hidden = true;
    errorBanner.hidden = true;

    const data = Object.fromEntries(new FormData(form));

    try {
      // Replace with your actual form endpoint (Netlify Forms, Resend, etc.)
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error("Submit failed");

      form.reset();
      fields.forEach((f) => f.removeAttribute("aria-invalid"));
      successMsg.hidden = false;
      successMsg.focus();
    } catch {
      errorBanner.hidden = false;
      errorBanner.focus();
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Send Message";
    }
  });
</script>

<style>
  .contact-page {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
    margin-top: 3rem;
  }

  /* Contact info panel */
  .contact-info-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-primary-700);
  }

  :global(.dark) .contact-info-heading {
    color: var(--color-primary-300);
  }

  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-base-500);
    margin-bottom: 0.25rem;
  }

  .contact-value {
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .contact-value:is(a):hover {
    color: var(--color-primary-700);
    text-decoration: underline;
  }

  /* Form */
  .contact-form-wrap {
    background-color: var(--bg-card);
    border-radius: 0.75rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--color-base-300);
    border-radius: 0.5rem;
    background-color: var(--bg-base);
    color: var(--color-text);
    font-size: 1rem;
    font-family: inherit;
    transition:
      border-color 150ms linear,
      box-shadow 150ms linear;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: 2px solid var(--color-primary-600);
    outline-offset: 2px;
    border-color: var(--color-primary-600);
  }

  .form-group input[aria-invalid="true"],
  .form-group select[aria-invalid="true"],
  .form-group textarea[aria-invalid="true"] {
    border-color: #c0392b;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .field-error {
    font-size: 0.875rem;
    color: #c0392b;
    min-height: 1.25rem;
  }

  .field-hint {
    font-size: 0.8125rem;
    color: var(--color-base-500);
  }

  .required-note {
    font-size: 0.875rem;
    color: var(--color-base-500);
    margin: 0;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
  }

  .btn-submit {
    padding: 0.75rem 2rem;
    background-color: var(--color-primary-900);
    color: var(--color-accent-light);
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition:
      background-color 150ms linear,
      opacity 150ms linear;
  }

  .btn-submit:hover {
    background-color: var(--color-primary-700);
  }

  .btn-submit:focus-visible {
    outline: 2px solid var(--color-primary-600);
    outline-offset: 3px;
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-success {
    padding: 1rem 1.25rem;
    background-color: color-mix(in srgb, #27ae60 15%, transparent);
    border: 1px solid #27ae60;
    border-radius: 0.5rem;
    color: var(--color-text);
  }

  .form-error-banner {
    padding: 1rem 1.25rem;
    background-color: color-mix(in srgb, #c0392b 15%, transparent);
    border: 1px solid #c0392b;
    border-radius: 0.5rem;
    color: var(--color-text);
  }

  .form-success p,
  .form-error-banner p {
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form-wrap {
      padding: 1.5rem;
    }
  }
</style>
