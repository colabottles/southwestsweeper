---
import { contentfulClient } from "../lib/contentful";
import type { RentalItem } from "../types/contentful";
import Layout from "../layouts/Layout.astro";

const entries = await contentfulClient.getEntries<RentalItem>({
  content_type: "rentalItem",
  order: ["fields.sortOrder"] as any,
});

const items = entries.items.map((item) => item.fields);

const grouped = items.reduce(
  (acc, item) => {
    if (!acc[item.category]) acc[item.category] = [];
    acc[item.category].push(item);
    return acc;
  },
  {} as Record<string, typeof items>,
);
---

<Layout title="Rentals">
  <main class="site-main">
    <div class="rentals-page">
      <div class="container container--wide">
        <div class="section-header">
          <div class="title2"><h2>Equipment Rentals</h2></div>
          <h1 class="title">Rental Pricing</h1>
          <p class="subtitle">
            Flexible rental periods to fit your needs — by the day, week, or
            month.
          </p>
        </div>

        {
          Object.entries(grouped).map(([category, rows]) => (
            <section
              class="rentals-table-section"
              aria-labelledby={`cat-${category}`}
            >
              <h2 class="rentals-table-heading" id={`cat-${category}`}>
                {category}
              </h2>
              <div class="rentals-table-wrap">
                <table class="rentals-table">
                  <caption class="sr-only">{category} pricing</caption>
                  <thead>
                    <tr>
                      <th scope="col">Description</th>
                      <th scope="col">Per Day</th>
                      <th scope="col">Per Week</th>
                      <th scope="col">Per Month</th>
                    </tr>
                  </thead>
                  <tbody>
                    {rows.map((row) => (
                      <tr>
                        <td>{row.description}</td>
                        <td>${row.costPerDay}</td>
                        <td>${row.costPerWeek}</td>
                        <td>${row.costPerMonth}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<style>
  .rentals-page {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .rentals-table-section {
    margin-bottom: 3rem;
  }

  .rentals-table-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-primary-700);
  }

  .dark .rentals-table-heading {
    color: var(--color-primary-300);
  }

  .rentals-table-wrap {
    overflow-x: auto;
    border-radius: 0.75rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .rentals-table {
    width: 100%;
    border-collapse: collapse;
    background-color: var(--bg-card);
    font-size: 1rem;
  }

  .rentals-table thead {
    background-color: var(--color-primary-900);
    color: var(--color-accent-light);
  }

  .rentals-table thead th {
    padding: 1rem 1.5rem;
    text-align: left;
    font-weight: 600;
    letter-spacing: 0.025em;
    font-size: 0.875rem;
    text-transform: uppercase;
  }

  .rentals-table tbody tr {
    border-bottom: 1px solid var(--color-base-200);
    transition: background-color 200ms linear;
  }

  .dark .rentals-table tbody tr {
    border-bottom-color: var(--color-base-dark-700);
  }

  .rentals-table tbody tr:last-child {
    border-bottom: none;
  }

  .rentals-table tbody tr:hover {
    background-color: color-mix(in srgb, var(--color-primary) 5%, transparent);
  }

  .rentals-table td {
    padding: 1rem 1.5rem;
    vertical-align: middle;
  }

  .rentals-table td:first-child {
    font-weight: 500;
  }

  .rentals-table td:not(:first-child) {
    color: var(--color-primary-800);
    font-weight: 600;
  }

  .dark .rentals-table td:not(:first-child) {
    color: var(--color-primary-300);
  }

  :global(.dark) .rentals-table-heading {
    color: var(--color-primary-300);
  }

  :global(.dark) .rentals-table tbody tr {
    border-bottom-color: var(--color-base-dark-700);
  }

  :global(.dark) .rentals-table td:not(:first-child) {
    color: var(--color-primary-300);
  }
</style>
