---
import Container from "../../shared/Container.astro";
import CtaButton from "../../shared/CtaButton.astro";
import GradientText from "../../shared/GradientText.astro";
import LazyImage from "../../shared/LazyImage.astro";
import Paragraph from "../../shared/Paragraph.astro";
import SubTitle2 from "../../shared/SubTitle2.astro";
import Title2 from "../../shared/Title2.astro";
import { maintenanceSection } from "./data.ts";
export interface Props {
  className?: string;
}
const { className = "" } = Astro.props;
---

<section id="maintenance" class={className}>
  <Container><Title2>{maintenanceSection.title}</Title2></Container>
  <Container className="maintenance-layout">
    <div class="maintenance-text">
      <SubTitle2
        >{maintenanceSection.subheading1_1}<GradientText
          >{maintenanceSection.subheading1_2}</GradientText
        ></SubTitle2
      >
      <Paragraph>{maintenanceSection.description}</Paragraph>
      <ul class="maintenance-points">
        {
          maintenanceSection.impactPoints.map((point) => (
            <li>
              <Paragraph className="font-normal">
                <span class="maintenance-point-check" aria-hidden="true">
                  &#10003;
                </span>
                {point}
              </Paragraph>
            </li>
          ))
        }
      </ul>
      <div class="maintenance-cta">
        <CtaButton>{maintenanceSection.button}</CtaButton>
      </div>
    </div>
    <div class="maintenance-image">
      <LazyImage
        src={maintenanceSection.visual}
        alt="Maintenance equipment"
        width="700"
        class="w-full h-full object-cover rounded-2xl"
      />
    </div>
  </Container>
</section>
