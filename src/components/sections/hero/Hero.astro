---
import heroImg from "./assets/azcacti.jpg";
import CtaButton from "../../shared/CtaButton.astro";
import GradientText from "../../shared/GradientText.astro";
import SubTitle from "../../shared/SubTitle.astro";
import Title from "../../shared/Title.astro";
import LazyImage from "../../shared/LazyImage.astro";
const heroSection = {
  headline1: "Serving the ",
  headline2: "Arizona Valley ",
  headline3: "Since ",
  headline4: "1975!",
  subheading1: "Inside, outside, everywhere you drive, ",
  subheading2: "we've got you covered.",
  buttonText: "Contact Us Today!",
};
export interface Props {
  className?: string;
}
const { className = "" } = Astro.props;
---

<section class={`hero ${className}`} id="hero">
  <div class="hero-inner">
    <div class="hero-grid">
      <div class="hero-content">
        <Title
          >{heroSection.headline1}
          <GradientText
            >{" " + heroSection.headline2}<br />{
              " " + heroSection.headline3
            }</GradientText
          >{heroSection.headline4}</Title
        >
        <SubTitle className="hero-subtitle"
          >{heroSection.subheading1}<br />{heroSection.subheading2}</SubTitle
        >
        <div class="hero-cta">
          <CtaButton>{heroSection.buttonText}</CtaButton>
        </div>
      </div>
      <div class="hero-image-wrap">
        <LazyImage
          src={heroImg}
          alt="Arizona cacti landscape"
          className="w-full h-full object-cover"
        />
        <svg
          class="hero-svg-overlay"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 500 400"
          aria-hidden="true"><path d="M0 0l0 400L100 0Z"></path></svg
        >
      </div>
    </div>
  </div>
</section>
