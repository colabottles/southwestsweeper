---
import Title3 from "../../../shared/Title3.astro";
import LazyImage from "../../../shared/LazyImage.astro";
export interface Props {
  title: string;
  description: string;
  visual: ImageMetadata;
}
const { title, description, visual } = Astro.props;
---

<div class="service-card">
  <LazyImage src={visual} alt={title} height="400" class="service-card-image" />
  <div class="service-card-overlay"></div>
  <div class="service-card-body">
    <div class="service-card-title">
      <Title3 className="title3--no-mb">{title}</Title3>
    </div>
    <div class="service-card-desc">{description}</div>
  </div>
</div>
